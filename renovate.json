{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "matchManagers": ["cargo"],
      "groupName": "Rust dependencies",
      "automerge": false
    },
    {
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "JS dev dependencies (minor/patch)",
      "automerge": true
    },
    {
      "matchPackageNames": ["@napi-rs/cli", "napi", "napi-derive"],
      "groupName": "napi-rs",
      "automerge": false
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 3am on monday"]
  }
}
